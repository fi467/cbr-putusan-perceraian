        "def pdf_to_text(pdf_file):\n",
        "\n",
        "    text = []\n",
        "\n",
        "    try:\n",
        "\n",
        "        with pdfplumber.open(pdf_file) as pdf:\n",
        "\n",
        "            for page in pdf.pages:\n",
        "\n",
        "                t = page.extract_text()\n",
        "\n",
        "                if t:\n",
        "                    text.append(t)\n",
        "\n",
        "    except:\n",
        "        pass\n",
        "\n",
        "    return \"\\n\".join(text)"
      ],
      "metadata": {
        "id": "60vHYoIRZqas"
      },
      "execution_count": 9,
      "outputs": []
