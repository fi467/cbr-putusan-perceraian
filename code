    {
      "cell_type": "code",
      "source": [
        "def clean_text(text):\n",
        "\n",
        "    text = text.lower()\n",
        "\n",
        "    text = re.sub(r'\\n+', ' ', text)\n",
        "\n",
        "    text = re.sub(r'\\s+', ' ', text)\n",
        "\n",
        "    text = re.sub(r'halaman\\s+\\d+', ' ', text)\n",
        "\n",
        "    text = re.sub(r'www\\.[^\\s]+', ' ', text)\n",
        "\n",
        "    text = re.sub(r'putusan\\.mahkamahagung\\.go\\.id', ' ', text)\n",
        "\n",
        "    return text.strip()"
      ],
