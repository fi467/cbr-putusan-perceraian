        "def parse_case_page(url):\n",
        "\n",
        "    r = requests.get(url, timeout=30)\n",
        "\n",
        "    soup = BeautifulSoup(r.text, \"html.parser\")\n",
        "\n",
        "    text = soup.get_text(\" \", strip=True)\n",
        "\n",
        "    nomor = \"\"\n",
        "\n",
        "    m = re.search(r\"Nomor\\s+([A-Za-z0-9./-]+)\", text)\n",
        "\n",
        "    if m:\n",
        "        nomor = m.group(1)\n",
        "\n",
        "    pdf_url = None\n",
        "\n",
        "    for a in soup.find_all(\"a\", href=True):\n",
        "\n",
        "        href = a[\"href\"]\n",
        "\n",
        "        if \".pdf\" in href.lower() or \"download_file\" in href:\n",
        "\n",
        "            if href.startswith(\"http\"):\n",
        "                pdf_url = href\n",
        "            else:\n",
        "                pdf_url = BASE_URL + href\n",
        "\n",
        "            break\n",
        "\n",
        "    return {\n",
        "        \"nomor\": nomor,\n",
        "        \"url\": url,\n",
        "        \"pdf_url\": pdf_url\n",
        "    }"
      ],
      "metadata": {
        "id": "xP7PUOKrZi1O"
      },
      "execution_count": 7,
      "outputs": []
    },
